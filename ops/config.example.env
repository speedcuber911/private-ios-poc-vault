# Copy to ~/.poc-vault/secrets/config.env and fill in local values.
AWS_REGION=ap-south-1
DOMAIN_ROOT=example.com
VAULT_DOMAIN=vault.pocs.example.com
POC_WILDCARD_DOMAIN=*.pocs.example.com
HOSTED_ZONE_ID=
INSTANCE_TYPE=t3.micro
KEY_NAME=poc-vault
KEY_PATH=$HOME/.poc-vault/secrets/ssh/poc-vault.pem
ADMIN_CIDR=
DEPLOY_USER=deploy
DEPLOY_HOST=
SERVER_ROOT=/srv/poc-vault
LOCAL_SECRETS_DIR=$HOME/.poc-vault/secrets
CLIENT_CERT_DAYS=90
BUNDLE_ID=com.example.pocvault
DEVELOPMENT_TEAM=
POC_VAULT_MANIFEST_URL=https://vault.pocs.example.com/manifest.json
POC_VAULT_SIGNATURE_URL=https://vault.pocs.example.com/manifest.sig.json
